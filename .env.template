# Anthropic API Key for ReAct Agent
# If empty, the backend will run in Mock Mode
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily API Key for web searches & extract
# If empty, the backend will run in Mock Mode
TAVILY_API_KEY=your_tavily_api_key_here

# Supabase Credentials for Dossier History
# If empty, the backend will store dossiers in-memory
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Clerk Credentials for Auth Verification
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Frontend Environment Variables (for reference)
VITE_API_BASE_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
