# ─── LLM Provider Keys (at least one required) ──────────────────────────────
# Priority order: Gemini > Groq > Anthropic

# Gemini API Key (Free Tier - 15 RPM)
# https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Free Tier - fast inference)
# https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API Key (Paid - Claude 3.5 Haiku + Sonnet)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Search & Scraping Keys ─────────────────────────────────────────────────

# Tavily API Key for web searches & extract (required)
# https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Firecrawl API Key for robust scraping (optional, free tier available)
# https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ─── Database ───────────────────────────────────────────────────────────────
# If empty, the backend will store dossiers in-memory

SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Auth ───────────────────────────────────────────────────────────────────

CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# ─── Frontend Environment Variables ─────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
